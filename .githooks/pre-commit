#!/usr/bin/env bash
# =============================================================================
# RavenClaw — Pre-Commit Hook
# =============================================================================
# Runs fast verification checks before each commit:
#   1. cargo fmt --check        — formatting
#   2. cargo clippy -D warnings — linting
#   3. cargo test --locked      — unit tests
#   4. Binary size check        — ensure under 5MB
#   5. No hardcoded secrets     — basic scan
#
# These checks are designed to complete in under 30 seconds on modern hardware.
# Longer-running checks (Docker, K8s, cross-compile) run in pre-push.
#
# Install: make this repo's .githooks directory active:
#   git config core.hooksPath .githooks
# Or run:  .githooks/setup.sh
# =============================================================================

set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ── Paths ─────────────────────────────────────────────────────────────────────
PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BINARY="$PROJECT_DIR/target/release/ravenclaw"
PASS=0
FAIL=0

# ── Helpers ───────────────────────────────────────────────────────────────────

ok()   { echo -e "  ${GREEN}✓${NC} $1"; PASS=$((PASS + 1)); }
fail() { echo -e "  ${RED}✗${NC} $1"; FAIL=$((FAIL + 1)); }
info() { echo -e "  ${CYAN}→${NC} $1"; }
step() { echo -e "\n${CYAN}══ $1 ══${NC}"; }

summary() {
    local total=$((PASS + FAIL))
    echo -e "\n${CYAN}════════════════════════════════════════════════${NC}"
    echo -e "  Pre-Commit: ${GREEN}${PASS} passed${NC}, ${RED}${FAIL} failed${NC} (${total} total)"
    echo -e "${CYAN}════════════════════════════════════════════════${NC}"
    if [[ $FAIL -gt 0 ]]; then
        echo -e "  ${RED}✗ COMMIT REJECTED — fix errors above and try again${NC}"
        echo -e "  ${YELLOW}  To skip checks (not recommended): git commit --no-verify${NC}"
    else
        echo -e "  ${GREEN}✓ ALL CHECKS PASSED — committing${NC}"
    fi
    echo ""
    return $FAIL
}

# ── Checks ────────────────────────────────────────────────────────────────────

check_fmt() {
    step "1. Formatting (cargo fmt --check)"
    if cargo fmt --check 2>/dev/null; then
        ok "Code is properly formatted"
    else
        fail "Formatting issues found — run 'cargo fmt' to fix"
        return
    fi
}

check_clippy() {
    step "2. Linting (cargo clippy -D warnings)"
    if cargo clippy --locked --all-targets -- -D warnings 2>/dev/null; then
        ok "No clippy warnings"
    else
        fail "Clippy warnings found — fix them before committing"
        return
    fi
}

check_tests() {
    step "3. Unit Tests (cargo test --locked)"
    if cargo test --locked 2>/dev/null; then
        ok "All ${GREEN}unit tests passed"
    else
        fail "Unit tests failed — fix before committing"
        return
    fi
}

check_binary_size() {
    step "4. Binary Size Check"
    if [[ ! -x "$BINARY" ]]; then
        info "No release binary found — skipping size check (run 'cargo build --release' for full verification)"
        return
    fi
    local size
    size=$(stat -f%z "$BINARY" 2>/dev/null || stat -c%s "$BINARY" 2>/dev/null || echo 0)
    local size_mb=$((size / 1024 / 1024))
    if [[ "$size" -lt 5000000 ]]; then
        ok "Binary size: ${size_mb}MB (under 5MB)"
    elif [[ "$size" -lt 10000000 ]]; then
        info "Binary size: ${size_mb}MB (under 10MB — acceptable)"
    else
        fail "Binary size: ${size_mb}MB (over 10MB — investigate)"
    fi
}

check_secrets() {
    step "5. Secrets Scan"
    if [[ ! -x "$BINARY" ]]; then
        # Scan staged source files instead
        local staged_files
        staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '\.(rs|toml|yaml|yml|sh|md)$' || true)
        if [[ -z "$staged_files" ]]; then
            info "No staged source files to scan for secrets"
            return
        fi
        local found=0
        while IFS= read -r file; do
            if git show ":${file}" 2>/dev/null | grep -qiE '(sk-[a-zA-Z0-9]{20,})|(ghp_[a-zA-Z0-9]{36})|(AKIA[0-9A-Z]{16})' 2>/dev/null; then
                echo -e "    ${RED}⚠ Potential secret found in: ${file}${NC}"
                found=1
            fi
        done <<< "$staged_files"
        if [[ $found -eq 0 ]]; then
            ok "No hardcoded secrets detected in staged files"
        else
            fail "Potential secrets found — review and remove before committing"
        fi
    else
        # Scan binary strings
        if strings "$BINARY" 2>/dev/null | grep -qiE '(sk-[a-zA-Z0-9]{20,})|(ghp_[a-zA-Z0-9]{36})' 2>/dev/null; then
            fail "Potential secrets found in binary strings"
        else
            ok "No hardcoded secrets detected in binary"
        fi
    fi
}

# ── Main ──────────────────────────────────────────────────────────────────────

echo ""
echo -e "${CYAN}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     RavenClaw Pre-Commit Verification           ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════════════════╝${NC}"

cd "$PROJECT_DIR"

check_fmt
check_clippy
check_tests
check_binary_size
check_secrets

summary
exit $?
