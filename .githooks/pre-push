#!/usr/bin/env bash
# =============================================================================
# RavenClaws — Pre-Push Hook
# =============================================================================
# Runs comprehensive verification before pushing to remote:
#   1. Full pre-commit checks (fmt + clippy + test + binary + secrets)
#   2. Release build
#   3. Binary integrity (stripped, architecture, size)
#   4. Docker build (if Docker is available)
#   5. Security scan (if binary exists)
#
# These checks take longer (1-5 minutes) but catch issues before CI.
# Install: git config core.hooksPath .githooks
# =============================================================================

set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BINARY="$PROJECT_DIR/target/release/ravenclaws"
PASS=0
FAIL=0
SKIP=0

ok()    { echo -e "  ${GREEN}✓${NC} $1"; PASS=$((PASS + 1)); }
fail()  { echo -e "  ${RED}✗${NC} $1"; FAIL=$((FAIL + 1)); }
skip()  { echo -e "  ${YELLOW}⊘${NC} $1"; SKIP=$((SKIP + 1)); }
info()  { echo -e "  ${CYAN}→${NC} $1"; }
step()  { echo -e "\n${CYAN}══ $1 ══${NC}"; }

summary() {
    local total=$((PASS + FAIL + SKIP))
    echo -e "\n${CYAN}════════════════════════════════════════════════${NC}"
    echo -e "  Pre-Push: ${GREEN}${PASS} passed${NC}, ${RED}${FAIL} failed${NC}, ${YELLOW}${SKIP} skipped${NC} (${total} total)"
    echo -e "${CYAN}════════════════════════════════════════════════${NC}"
    if [[ $FAIL -gt 0 ]]; then
        echo -e "  ${RED}✗ PUSH REJECTED — fix errors above and try again${NC}"
        echo -e "  ${YELLOW}  To skip checks: git push --no-verify${NC}"
    else
        echo -e "  ${GREEN}✓ ALL CHECKS PASSED — pushing${NC}"
    fi
    echo ""
    return $FAIL
}

# ── Pre-commit checks (reuse the pre-commit script) ──────────────────────────

run_pre_commit() {
    step "1. Pre-Commit Checks"
    if "$PROJECT_DIR/.githooks/pre-commit"; then
        ok "Pre-commit checks passed"
    else
        fail "Pre-commit checks failed — fix before pushing"
    fi
}

# ── Release build ─────────────────────────────────────────────────────────────

check_release_build() {
    step "2. Release Build"
    info "Building release binary..."
    if cargo build --release 2>/dev/null; then
        local size
        size=$(stat -f%z "$BINARY" 2>/dev/null || stat -c%s "$BINARY" 2>/dev/null || echo 0)
        local size_mb=$((size / 1024 / 1024))
        ok "Release build successful (${size_mb}MB)"
    else
        fail "Release build failed"
    fi
}

# ── Binary integrity ──────────────────────────────────────────────────────────

check_binary_integrity() {
    step "3. Binary Integrity"
    if [[ ! -x "$BINARY" ]]; then
        skip "No binary to check"
        return
    fi

    # Architecture
    if file "$BINARY" 2>/dev/null | grep -q 'Mach-O 64-bit executable arm64'; then
        ok "Binary is aarch64 Mach-O 64-bit"
    else
        fail "Binary architecture check failed ($(file "$BINARY" 2>/dev/null | head -1))"
    fi

    # Stripped (release build)
    if file "$BINARY" 2>/dev/null | grep -q 'executable'; then
        ok "Binary is a release executable"
    else
        fail "Binary is not a release executable"
    fi

    # Size check
    local size
    size=$(stat -f%z "$BINARY" 2>/dev/null || stat -c%s "$BINARY" 2>/dev/null || echo 0)
    local size_mb=$((size / 1024 / 1024))
    if [[ "$size" -lt 5000000 ]]; then
        ok "Binary size: ${size_mb}MB (under 5MB)"
    elif [[ "$size" -lt 10000000 ]]; then
        info "Binary size: ${size_mb}MB (under 10MB)"
    else
        fail "Binary size: ${size_mb}MB (over 10MB)"
    fi
}

# ── Docker build ──────────────────────────────────────────────────────────────

check_docker_build() {
    step "4. Docker Build"
    if ! command -v docker &>/dev/null; then
        skip "Docker not available"
        return
    fi
    info "Building Docker image..."
    if docker build -t ravenclaws-pre-push "$PROJECT_DIR" >/dev/null 2>&1; then
        ok "Docker build successful"
        # Clean up
        docker rmi ravenclaws-pre-push >/dev/null 2>&1 || true
    else
        fail "Docker build failed"
    fi
}

# ── Security scan ─────────────────────────────────────────────────────────────

check_security() {
    step "5. Security Scan"
    if [[ ! -x "$BINARY" ]]; then
        skip "No binary to scan"
        return
    fi

    # No hardcoded secrets in binary
    if strings "$BINARY" 2>/dev/null | grep -qiE '(sk-[a-zA-Z0-9]{20,})|(ghp_[a-zA-Z0-9]{36})' 2>/dev/null; then
        fail "Potential secrets found in binary strings"
    else
        ok "No hardcoded secrets in binary"
    fi

    # No setuid/setgid
    if test ! -u "$BINARY" && test ! -g "$BINARY"; then
        ok "Binary has no setuid/setgid"
    else
        fail "Binary has setuid or setgid set"
    fi

    # Cargo.lock exists
    if [[ -f "$PROJECT_DIR/Cargo.lock" ]]; then
        ok "Cargo.lock present (reproducible builds)"
    else
        fail "Cargo.lock missing — run 'cargo generate-lockfile'"
    fi
}

# ── Main ──────────────────────────────────────────────────────────────────────

echo ""
echo -e "${CYAN}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     RavenClaws Pre-Push Verification             ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════════════════╝${NC}"

cd "$PROJECT_DIR"

run_pre_commit
check_release_build
check_binary_integrity
check_docker_build
check_security

summary
exit $?
