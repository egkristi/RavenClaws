[0.006, "o", "#!/usr/bin/env bash\r\n# =============================================================================\r\n# RavenClaws вЂ” Pre-Commit Hook\r\n# =============================================================================\r\n# Runs fast verification checks before each commit:\r\n#   1. cargo fmt --check        вЂ” formatting\r\n#   2. cargo clippy -D warnings вЂ” linting\r\n#   3. cargo test --locked      вЂ” unit tests\r\n#   4. Binary size check        вЂ” ensure under 5MB\r\n#   5. No hardcoded secrets     вЂ” basic scan\r\n#\r\n# These checks are designed to complete in under 30 seconds on modern hardware.\r\n# Longer-running checks (Docker, K8s, cross-compile) run in pre-push.\r\n#\r\n# Install: make this repo's .githooks directory active:\r\n#   git config core.hooksPath .githooks\r\n# Or run:  .githooks/setup.sh\r\n# =============================================================================\r\n\r\nset -euo pipefail\r\n"]
[1.012, "o", "\r\n"]
