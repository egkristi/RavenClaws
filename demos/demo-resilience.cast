[0.016, "o", "\r\n╔══════════════════════════════════════════════════════════════╗\r\n║  1. SELF-HEALING ENGINE OVERVIEW\r\n╚══════════════════════════════════════════════════════════════╝\r\n\r\n"]
[0.003, "o", "$ cat src/healing.rs\r\n"]
[0.000, "o", "//! Self-healing engine — automatic detection, retry, and recovery of failed agents\r\n//!\r\n//! # Dead code note\r\n//! Some fields and methods are `#[allow(dead_code)]` because they are used by\r\n//! library tests but not yet by the binary target. As healing is wired into\r\n//! more modules (swarm, heartbeat, background, patterns), these will become\r\n//! used by the binary as well.\r\n\r\n// Allow dead code for fields/methods used only by library tests\r\n#![allow(dead_code)]\r\n//!\r\n//! RavenClaws's self-healing system extends the v1.2.0 retry logic from individual\r\n//! LLM calls to the full agent, swarm, and task level. It provides:\r\n//!\r\n//! - **Failure tracking** — per-agent/worker failure records with timestamps\r\n//! - **Circuit breakers** — per-agent circuit state (Closed/Open/HalfOpen)\r\n//! - **Exponential backoff** — configurable retry delays for agent tasks\r\n//! - **Auto-replacement** — detect dead workers and trigger replacement\r\n//! - **Health checks** — verify agent health before delegation\r\n//!\r\n/"]
[0.000, "o", "/! # Architecture\r\n//!\r\n//! ```text\r\n//! SelfHealingEngine\r\n"]
[0.000, "o", "//!   ├── HealingConfig — retry limits, backoff, circuit breaker settings\r\n"]
[0.000, "o", "//!   ├── failure_records: HashMap<String, FailureRecord> — per-agent failures\r\n//!   ├── circuit_breakers: HashMap<String, HealingCircuitBreaker> — per-agent circuits\r\n//!   └── Methods:\r\n//!       ├── record_failure() — track a failure for an agent\r\n"]
[1.009, "o", "\r\n╔══════════════════════════════════════════════════════════════╗\r\n║  2. CIRCUIT BREAKER STATES\r\n╚══════════════════════════════════════════════════════════════╝\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "$ grep -A 10 pub enum HealingCircuitState src/healing.rs\r\n"]
[0.004, "o", "pub enum HealingCircuitState {\r\n    /// Normal operation — requests allowed\r\n    Closed,\r\n    /// Failure threshold exceeded — requests blocked\r\n    Open,\r\n    /// Recovery period — one request allowed to test\r\n    HalfOpen,\r\n}\r\n\r\n/// Per-agent circuit breaker tracking failure counts and state transitions.\r\n#[derive(Debug, Clone)]\r\n"]
[1.009, "o", "\r\n╔══════════════════════════════════════════════════════════════╗\r\n║  3. SELF-HEALING ENGINE STRUCT\r\n"]
[0.000, "o", "╚══════════════════════════════════════════════════════════════╝\r\n\r\n"]
[0.000, "o", "$ grep -A 15 pub struct SelfHealingEngine src/healing.rs\r\n"]
[0.006, "o", "pub struct SelfHealingEngine {\r\n    /// Configuration\r\n    pub config: HealingConfig,\r\n    /// Per-agent failure records\r\n    failure_records: HashMap<String, FailureRecord>,\r\n    /// Per-agent circuit breakers\r\n    circuit_breakers: HashMap<String, HealingCircuitBreaker>,\r\n}\r\n\r\nimpl SelfHealingEngine {\r\n    /// Create a new self-healing engine with default configuration.\r\n    pub fn new() -> Self {\r\n        Self {\r\n            config: HealingConfig::default(),\r\n"]
[0.000, "o", "            failure_records: HashMap::new(),\r\n            circuit_breakers: HashMap::new(),\r\n"]
[1.007, "o", "\r\n"]
[0.000, "o", "╔══════════════════════════════════════════════════════════════╗\r\n"]
[0.000, "o", "║  4. FAILURE RECORD TRACKING\r\n"]
[0.000, "o", "╚══════════════════════════════════════════════════════════════╝\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "$ grep -A 15 pub struct FailureRecord src/healing.rs\r\n"]
[0.006, "o", "pub struct FailureRecord {\r\n    /// Agent/worker identifier\r\n    pub agent_id: String,\r\n    /// Number of consecutive failures\r\n    pub failure_count: u32,\r\n    /// Timestamp of first failure in this sequence\r\n    pub first_failure: Instant,\r\n    /// Timestamp of most recent failure\r\n    pub last_failure: Instant,\r\n    /// Error message from the most recent failure\r\n    pub last_error: String,\r\n    /// Whether this agent is considered dead\r\n    pub is_dead: bool,\r\n}\r\n\r\nimpl FailureRecord {\r\n"]
[1.014, "o", "\r\n╔══════════════════════════════════════════════════════════════╗\r\n║  5. RETRY WITH EXPONENTIAL BACKOFF\r\n"]
[0.000, "o", "╚══════════════════════════════════════════════════════════════╝\r\n\r\n"]
[0.005, "o", "$ grep -A 20 pub async fn retry_with_backoff src/healing.rs\r\n"]
[0.001, "o", "    pub async fn retry_with_backoff<F, T>(\r\n        &self,\r\n        agent_id: &str,\r\n        is_transient: impl Fn(&str) -> bool,\r\n        mut operation: F,\r\n    ) -> Result<T, String>\r\n    where\r\n        F: FnMut(u32) -> Result<T, String>,\r\n    {\r\n        let max_attempts = self.config.max_retries + 1; // +1 for the initial attempt\r\n        let mut last_error = String::from(\"Unknown error\");\r\n\r\n        for attempt in 0..max_attempts {\r\n            if attempt > 0 {\r\n                let delay = self.delay_for_attempt(attempt - 1);\r\n                debug!(\r\n                    agent_id = %agent_id,\r\n                    attempt = attempt,\r\n                    delay_ms = delay.as_millis(),\r\n"]
[1.009, "o", "\r\n╔══════════════════════════════════════════════════════════════╗\r\n"]
[0.000, "o", "║  6. GRACEFUL DEGRADATION\r\n"]
[0.000, "o", "╚══════════════════════════════════════════════════════════════╝\r\n\r\n"]
[0.000, "o", "$ grep -A 10 pub struct LoadManager src/load.rs\r\n"]
[0.007, "o", "pub struct LoadManager {\r\n    /// Configuration\r\n    config: LoadConfig,\r\n    /// Token bucket for rate limiting\r\n    rate_limiter: Option<TokenBucket>,\r\n    /// Semaphore for concurrency limiting\r\n    concurrency_limiter: Option<Arc<Semaphore>>,\r\n    /// Error rate tracker for overload detection\r\n    error_tracker: ErrorTracker,\r\n    /// Current queue depth estimate\r\n    queue_depth: AtomicU64,\r\n"]
[0.508, "o", "$ grep -A 10 pub struct TokenBucket src/load.rs\r\n"]
[0.007, "o", "pub struct TokenBucket {\r\n    /// Tokens currently available\r\n    tokens: AtomicU64,\r\n    /// Maximum tokens (burst size)\r\n    capacity: u64,\r\n    /// Tokens added per second\r\n    rate_per_sec: u64,\r\n    /// Last refill timestamp (nanoseconds)\r\n    last_refill: AtomicU64,\r\n}\r\n\r\n"]
[0.515, "o", "$ grep -A 10 pub struct LoadConfig src/load.rs\r\n"]
[0.004, "o", "pub struct LoadConfig {\r\n    /// Maximum number of concurrent in-flight requests (0 = unlimited)\r\n    #[serde(default = \"default_max_concurrent\")]\r\n    pub max_concurrent_requests: usize,\r\n\r\n    /// Rate limit: maximum requests per second (0 = unlimited)\r\n    #[serde(default = \"default_rate_limit\")]\r\n    pub rate_limit_per_second: u64,\r\n\r\n    /// Rate limit: maximum burst size (0 = use rate_limit_per_second)\r\n    #[serde(default = \"default_rate_burst\")]\r\n"]
[1.010, "o", "\r\n╔══════════════════════════════════════════════════════════════╗\r\n║  7. SELF-HEALING UNIT TESTS\r\n╚══════════════════════════════════════════════════════════════╝\r\n\r\n"]
[0.007, "o", "$ grep -A 5 #\\[test\\] src/healing.rs\r\n"]
[0.000, "o", "    #[test]\r\n    fn test_healing_config_default() {\r\n        let config = HealingConfig::default();\r\n        assert_eq!(config.max_retries, 3);\r\n        assert_eq!(config.base_delay_ms, 1000);\r\n        assert_eq!(config.max_delay_ms, 30000);\r\n--\r\n    #[test]\r\n    fn test_circuit_breaker_initial_state() {\r\n        let mut cb = HealingCircuitBreaker::new(30, 5);\r\n        assert_eq!(cb.state, HealingCircuitState::Closed);\r\n        assert_eq!(cb.failure_count, 0);\r\n        assert!(cb.can_execute());\r\n--\r\n    #[test]\r\n    fn test_circuit_breaker_opens_after_threshold() {\r\n        let mut cb = HealingCircuitBreaker::new(30, 3);\r\n        assert!(cb.can_execute());\r\n\r\n        cb.record_failure();\r\n--\r\n"]
[0.000, "o", "    #[test]\r\n    fn test_circuit_breaker_success_resets() {\r\n        let mut cb = HealingCircuitBreaker::new(30, 3);\r\n        cb.record_failure();\r\n        cb.record_failure();\r\n"]
[0.000, "o", "        assert_eq!(cb.failure_count, 2);\r\n--\r\n    #[test]\r\n"]
[1.011, "o", "\r\n"]
[0.001, "o", "╔══════════════════════════════════════════════════════════════╗\r\n"]
